# NanoPi M4B Platform Configuration
PLATFORM_NAME="NanoPi M4B"
PLATFORM_ARCH="aarch64"

# Docker configuration (requires fixes)
DOCKER_STORAGE_DRIVER="fuse-overlayfs"
DOCKER_USE_LEGACY_IPTABLES="true"
DOCKER_USE_FUSE_OVERLAYFS="true"

# System packages
BASE_PACKAGES="curl ca-certificates wget netcat-openbsd git alsa-utils sox python3 python3-pip python3-scipy python3-numpy libusb-1.0-0 sqlite3 fuse-overlayfs iptables"

# Audio configuration
AUDIO_RESAMPLE_RATE="48000"
AUDIO_CAPTURE_RATE="16000"
