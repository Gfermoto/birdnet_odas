# Raspberry Pi Platform Configuration
PLATFORM_NAME="Raspberry Pi (CM4/Pi4/Pi5)"
PLATFORM_ARCH="aarch64"

# Docker configuration
DOCKER_STORAGE_DRIVER="overlay2"
DOCKER_USE_LEGACY_IPTABLES="false"
DOCKER_USE_FUSE_OVERLAYFS="false"

# System packages
BASE_PACKAGES="curl ca-certificates wget netcat-openbsd git alsa-utils sox python3 python3-pip python3-scipy python3-numpy libusb-1.0-0 sqlite3"

# Audio configuration  
AUDIO_RESAMPLE_RATE="48000"
AUDIO_CAPTURE_RATE="16000"
